        {FIELDS.map((field) => (
          <label key={field.key} className="flex flex-col gap-1">
            <span className="text-[11px] font-medium text-steel-400">
              {field.label}
            </span>
            {field.type === "select" ? (
              <select
                value={lineData[field.key]}
                onChange={(e) => onChange(field.key, e.target.value)}
                className="rounded border border-border bg-surface px-2 py-1.5 text-sm text-steel-50 focus:border-steel-400 focus:outline-none"
              >
                {field.options?.map((opt) => (
                  <option key={opt} value={opt}>
                    {opt}
                  </option>
                ))}
              </select>
            ) : (
              <input
                value={lineData[field.key]}
                onChange={(e) => onChange(field.key, e.target.value)}
                className="rounded border border-border bg-surface px-2 py-1.5 text-sm text-steel-50 focus:border-steel-400 focus:outline-none"
              />
            )}
          </label>
        ))}
      </div>
    </section>
  );
}

"use client";

import { ToastMessage } from "@/types/engineering";

const VARIANT_STYLES: Record<ToastMessage["variant"], string> = {
  success: "border-signal-ok/40 bg-signal-ok/10 text-signal-ok",
  error: "border-signal-critical/40 bg-signal-critical/10 text-signal-critical",
  info: "border-signal-info/40 bg-signal-info/10 text-signal-info",
};

export default function Toast({ toasts }: { toasts: ToastMessage[] }) {
  if (toasts.length === 0) return null;

  return (
    <div className="pointer-events-none fixed bottom-4 right-4 z-[100] flex flex-col gap-2">
      {toasts.map((toast) => (
        <div
          key={toast.id}
          className={`pointer-events-auto min-w-[220px] rounded border px-4 py-2.5 text-sm font-medium shadow-card ${VARIANT_STYLES[toast.variant]}`}
        >
          {toast.text}
        </div>
      ))}
    </div>
  );
}


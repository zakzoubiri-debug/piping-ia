"use client";

import { useState } from "react";
import { ConnectionAccessory, LineComponent } from "@/types/engineering";
import { CATEGORY_ORDER, COMPONENT_LIBRARY } from "@/lib/component-library";
import LineComponentCard from "./LineComponentCard";
import AccessoryNode from "./AccessoryNode";

interface LineCanvasProps {
  components: LineComponent[];
  onOpenComponent: (index: number) => void;
  onRemoveComponent: (index: number) => void;
  onMoveComponent: (index: number, direction: -1 | 1) => void;
  onDuplicateComponent: (index: number) => void;
  onAddComponentByTypeId: (typeId: string) => void;
  onClearLine: () => void;
  onResetDemo: () => void;
  onAnalyze: () => void;
}

/**
 * Builds the accessory sequence between two adjacent components. Flanged
 * components get a flange + gasket on the side facing the pipe run; butt
 * weld (and other) connection types are shown as a plain pipe segment.
 */
function buildConnector(
  left: LineComponent,
  right: LineComponent
): ConnectionAccessory[] {
  const segment: ConnectionAccessory[] = [];
  let n = 0;
  const key = `${left.instanceId}-${right.instanceId}`;
  const push = (kind: ConnectionAccessory["kind"]) => {
    segment.push({ id: `${key}-${n++}`, kind, label: kind });
  };

  if (left.connectionType === "Flanged") {
    push("Gasket");
    push("Flange");
  }
  push("Pipe");
  if (right.connectionType === "Flanged") {
    push("Flange");
    push("Gasket");
  }
  return segment;
}

export default function LineCanvas({
  components,
  onOpenComponent,
  onRemoveComponent,
  onMoveComponent,
  onDuplicateComponent,
  onAddComponentByTypeId,
  onClearLine,
  onResetDemo,
  onAnalyze,
}: LineCanvasProps) {
  const [quickAddOpen, setQuickAddOpen] = useState(false);
  const [quickAddValue, setQuickAddValue] = useState(
    COMPONENT_LIBRARY[0].typeId
  );

  return (
    <section className="flex flex-1 flex-col overflow-hidden">
      <div className="flex items-center justify-between gap-2 border-b border-border bg-panel px-5 py-2.5">
        <h2 className="text-xs font-semibold uppercase tracking-wider text-steel-300">
          Piping Line
        </h2>
        <div className="flex items-center gap-2">
          <div className="relative">
            <button
              onClick={() => setQuickAddOpen((v) => !v)}
              className="rounded border border-border bg-surface px-3 py-1.5 text-xs font-medium text-steel-100 transition hover:border-steel-500 hover:bg-surfaceAlt"
            >
              + Add Component
            </button>
            {quickAddOpen && (
              <div className="absolute right-0 top-9 z-10 w-56 rounded border border-border bg-surface p-2 shadow-card">
                <select
                  value={quickAddValue}
                  onChange={(e) => setQuickAddValue(e.target.value)}
                  className="mb-2 w-full rounded border border-border bg-surfaceAlt px-2 py-1.5 text-xs text-steel-50 focus:outline-none"
                >
                  {CATEGORY_ORDER.map((category) => (
                    <optgroup label={category} key={category}>
                      {COMPONENT_LIBRARY.filter(
                        (c) => c.category === category
                      ).map((c) => (
                        <option key={c.typeId} value={c.typeId}>
                          {c.name}
                        </option>
                      ))}
                    </optgroup>
                  ))}
                </select>
                <button
                  onClick={() => {
                    onAddComponentByTypeId(quickAddValue);
                    setQuickAddOpen(false);
                  }}
                  className="w-full rounded bg-accent px-2 py-1.5 text-xs font-semibold text-panel transition hover:brightness-110"
                >
                  Add to line
                </button>
              </div>
            )}
          </div>
          <button
            onClick={onClearLine}
            className="rounded border border-border bg-surface px-3 py-1.5 text-xs font-medium text-steel-100 transition hover:border-signal-critical hover:text-signal-critical"
          >
            Clear Line
          </button>
          <button
            onClick={onResetDemo}
            className="rounded border border-border bg-surface px-3 py-1.5 text-xs font-medium text-steel-100 transition hover:border-steel-500 hover:bg-surfaceAlt"
          >
            Reset Demo
          </button>
        </div>
      </div>

      <div className="flex-1 overflow-auto bg-[radial-gradient(circle,#2c3742_1px,transparent_1px)] [background-size:18px_18px] px-5 py-8">
        {components.length === 0 ? (
          <div className="flex h-full flex-col items-center justify-center gap-2 text-center">
            <span className="text-3xl text-steel-600">⌬</span>
            <p className="text-sm font-medium text-steel-200">
              This line is empty.
            </p>
            <p className="max-w-xs text-xs text-steel-500">
              Add a component from the left sidebar or use &ldquo;Add
              Component&rdquo; above to start building the piping line.
            </p>
          </div>
        ) : (
          <div className="flex min-w-max items-center gap-1">
            {components.map((component, index) => (
              <div key={component.instanceId} className="flex items-center">
                <LineComponentCard
                  component={component}
                  isFirst={index === 0}
                  isLast={index === components.length - 1}
                  onOpen={() => onOpenComponent(index)}
                  onRemove={() => onRemoveComponent(index)}
                  onMoveLeft={() => onMoveComponent(index, -1)}
                  onMoveRight={() => onMoveComponent(index, 1)}
                  onDuplicate={() => onDuplicateComponent(index)}
                />
                {index < components.length - 1 && (
                  <div className="flex items-center gap-1 px-1">
                    {buildConnector(component, components[index + 1]).map(
                      (accessory) => (
                        <AccessoryNode key={accessory.id} accessory={accessory} />
                      )
                    )}
                    <span className="text-steel-500">→</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      <div className="border-t border-border bg-panel px-5 py-4">
        <button
          onClick={onAnalyze}
          className="w-full rounded-md bg-accent py-3 text-sm font-semibold tracking-wide text-panel transition hover:brightness-110"
        >
          Analyze Line
        </button>
      </div>
    </section>
  );
}


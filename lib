import {
  AnalysisResult,
  AnalysisState,
  LineComponent,
  LineData,
} from "@/types/engineering";
import { ENGINEERING_RULES } from "./engineering-rules";

function parseNumber(value: string): number | null {
  const match = value.match(/-?\d+(\.\d+)?/);
  if (!match) return null;
  return parseFloat(match[0]);
}

function passResult(
  ruleId: string,
  message: string,
  reason: string
): AnalysisResult {
  return {
    ruleId,
    severity: "Passed",
    message,
    relatedComponent: "—",
    reason,
    action: "No action required at this time.",
  };
}

function triggerResult(
  ruleId: string,
  relatedComponent: string
): AnalysisResult {
  const rule = ENGINEERING_RULES[ruleId];
  return {
    ruleId,
    severity: rule.severity,
    message: rule.message,
    relatedComponent,
    reason: rule.reason,
    action: rule.action,
  };
}

/**
 * Runs the full set of preliminary design checks against the current line.
 * These checks are intentionally simple and are meant to flag items for
 * engineering review, not to replace one.
 */
export function analyzeLine(
  lineData: LineData,
  components: LineComponent[]
): AnalysisState {
  const results: AnalysisResult[] = [];

  // Rule 1: pump present, check valve must follow it somewhere downstream
  const pumpIndex = components.findIndex((c) => c.typeId === "pump");
  if (pumpIndex !== -1) {
    const hasCheckValveAfter = components
      .slice(pumpIndex + 1)
      .some((c) => c.typeId === "check-valve");
    const pumpTag = components[pumpIndex].tag;
    if (!hasCheckValveAfter) {
      results.push(triggerResult("rule-1-check-valve", pumpTag));
    } else {
      results.push(
        passResult(
          "rule-1-check-valve",
          "A check valve was found downstream of the pump discharge.",
          "Reverse-flow protection appears to be in place for this pump."
        )
      );
    }
  }

  // Rule 2: flow meter present
  const flowMeter = components.find((c) => c.typeId === "flow-meter");
  if (flowMeter) {
    results.push(triggerResult("rule-2-flow-meter", flowMeter.tag));
  } else {
    results.push(
      passResult(
        "rule-2-flow-meter",
        "No flow meter present on this line.",
        "Straight-length requirements are not applicable without a flow meter."
      )
    );
  }

  // Rule 3 & 4: control valve isolation
  const controlValveIndex = components.findIndex(
    (c) => c.typeId === "control-valve"
  );
  if (controlValveIndex !== -1) {
    const cvTag = components[controlValveIndex].tag;
    const hasUpstreamIsolation = components
      .slice(0, controlValveIndex)
      .some((c) => c.isIsolationValve);
    const hasDownstreamIsolation = components
      .slice(controlValveIndex + 1)
      .some((c) => c.isIsolationValve);

    if (!hasUpstreamIsolation) {
      results.push(triggerResult("rule-3-cv-upstream-isolation", cvTag));
    } else {
      results.push(
        passResult(
          "rule-3-cv-upstream-isolation",
          "An upstream isolation valve was found for the control valve.",
          "The control valve can be isolated from the upstream side for maintenance."
        )
      );
    }

    if (!hasDownstreamIsolation) {
      results.push(triggerResult("rule-4-cv-downstream-isolation", cvTag));
    } else {
      results.push(
        passResult(
          "rule-4-cv-downstream-isolation",
          "A downstream isolation valve was found for the control valve.",
          "The control valve can be isolated from the downstream side for maintenance."
        )
      );
    }
  }

  // Rule 5: temperature check
  const temperature = parseNumber(lineData.temperature);
  if (temperature !== null && temperature > 120) {
    results.push(triggerResult("rule-5-thermal-expansion", lineData.lineNumber));
  } else {
    results.push(
      passResult(
        "rule-5-thermal-expansion",
        "Operating temperature is at or below 120 °C.",
        "Thermal growth is less likely to be a governing concern at this temperature."
      )
    );
  }

  // Rule 6: line length check
  const length = parseNumber(lineData.lineLength);
  if (length !== null && length > 15) {
    results.push(triggerResult("rule-6-support-spacing", lineData.lineNumber));
  } else {
    results.push(
      passResult(
        "rule-6-support-spacing",
        "Line length is at or below 15 metres.",
        "Support spacing is less likely to be a governing concern at this length."
      )
    );
  }

  // Rule 7: concentric reducer on pump suction (upstream of the pump)
  if (pumpIndex > 0) {
    const suctionReducer = components
      .slice(0, pumpIndex)
      .find((c) => c.typeId === "concentric-reducer");
    if (suctionReducer) {
      results.push(
        triggerResult("rule-7-suction-reducer", suctionReducer.tag)
      );
    } else {
      results.push(
        passResult(
          "rule-7-suction-reducer",
          "No concentric reducer found on the pump suction line.",
          "Vapour-pocket risk from a concentric suction reducer does not apply here."
        )
      );
    }
  }

  // Rule 8: PSV present
  const psv = components.find((c) => c.typeId === "psv");
  if (psv) {
    results.push(triggerResult("rule-8-psv", psv.tag));
  } else {
    results.push(
      passResult(
        "rule-8-psv",
        "No PSV present on this line.",
        "Discharge routing and back-pressure checks are not applicable without a PSV."
      )
    );
  }

  // Rule 9: drain present
  const drain = components.find((c) => c.typeId === "drain");
  if (!drain) {
    results.push(triggerResult("rule-9-drain", lineData.lineNumber));
  } else {
    results.push(
      passResult(
        "rule-9-drain",
        "A drain is present on this line.",
        "Low-point drainage has already been considered."
      )
    );
  }

  // Rule 10: vent present
  const vent = components.find((c) => c.typeId === "vent");
  if (!vent) {
    results.push(triggerResult("rule-10-vent", lineData.lineNumber));
  } else {
    results.push(
      passResult(
        "rule-10-vent",
        "A vent is present on this line.",
        "High-point venting has already been considered."
      )
    );
  }

  const critical = results.filter((r) => r.severity === "Critical").length;
  const warnings = results.filter((r) => r.severity === "Warning").length;
  const information = results.filter(
    (r) => r.severity === "Information"
  ).length;
  const passed = results.filter((r) => r.severity === "Passed").length;

  let overallStatus: "Approved" | "Review Required" | "Critical Issues" =
    "Approved";
  if (critical > 0) {
    overallStatus = "Critical Issues";
  } else if (warnings > 0) {
    overallStatus = "Review Required";
  }

  return {
    results,
    summary: {
      totalChecks: results.length,
      critical,
      warnings,
      information,
      passed,
      overallStatus,
      generatedAt: new Date().toISOString(),
    },
  };
}


import {
  AnalysisState,
  ExportPayload,
  LineComponent,
  LineData,
} from "@/types/engineering";

export function buildExportPayload(
  lineData: LineData,
  components: LineComponent[],
  analysis: AnalysisState | null
): ExportPayload {
  return {
    lineData,
    components,
    analysis,
    exportDate: new Date().toISOString(),
  };
}

export function downloadLineExport(
  lineData: LineData,
  components: LineComponent[],
  analysis: AnalysisState | null
): void {
  const payload = buildExportPayload(lineData, components, analysis);
  const json = JSON.stringify(payload, null, 2);
  const blob = new Blob([json], { type: "application/json" });
  const url = URL.createObjectURL(blob);

  const link = document.createElement("a");
  const safeLineNumber = lineData.lineNumber.replace(/[^a-zA-Z0-9-_]/g, "_");
  link.href = url;
  link.download = `enghub-line-${safeLineNumber || "export"}.json`;
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
  URL.revokeObjectURL(url);
}

import { AnalysisState, LineComponent, LineData } from "@/types/engineering";

const STORAGE_KEY = "enghub.smart-line-builder.v1";

export interface PersistedLine {
  lineData: LineData;
  components: LineComponent[];
  analysis: AnalysisState | null;
  savedAt: string;
}

export function saveLine(
  lineData: LineData,
  components: LineComponent[],
  analysis: AnalysisState | null
): void {
  if (typeof window === "undefined") return;
  const payload: PersistedLine = {
    lineData,
    components,
    analysis,
    savedAt: new Date().toISOString(),
  };
  window.localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
}

export function loadLine(): PersistedLine | null {
  if (typeof window === "undefined") return null;
  const raw = window.localStorage.getItem(STORAGE_KEY);
  if (!raw) return null;
  try {
    return JSON.parse(raw) as PersistedLine;
  } catch {
    return null;
  }
}

export function clearSavedLine(): void {
  if (typeof window === "undefined") return;
  window.localStorage.removeItem(STORAGE_KEY);
}
